# Liquid-State Engine — Server Environment
#
# The dev server (scripts/serve.js) reads these environment variables.
# Set them before starting the server, or use a .env file.
#
# Required for AI enrichment:
#   DEEPSEEK_API_KEY — Your DeepSeek API key (from platform.deepseek.com)
#
# The API key is NEVER exposed to the browser. All AI calls are proxied
# through the server's /api/enrich endpoint.

DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
